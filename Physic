"""Moteur physique pour BounceBox."""

import math
from objets import Vector

class PhysicsEngine:
    @staticmethod
    def handle_wall_collision(ball, width, height):
        r = ball.radius
        bounced = False
        if ball.pos.x - r <= 0:
            ball.pos.x = r
            ball.vel.x = abs(ball.vel.x)
            bounced = True
        elif ball.pos.x + r >= width:
            ball.pos.x = width - r
            ball.vel.x = -abs(ball.vel.x)
            bounced = True
        if ball.pos.y - r <= 0:
            ball.pos.y = r
            ball.vel.y = abs(ball.vel.y)
            bounced = True
        elif ball.pos.y + r >= height:
            ball.pos.y = height - r
            ball.vel.y = -abs(ball.vel.y)
            bounced = True
        return bounced

    @staticmethod
    def check_collision(b1, b2):
        dx = b1.pos.x - b2.pos.x
        dy = b1.pos.y - b2.pos.y
        return math.sqrt(dx*dx + dy*dy) < (b1.radius + b2.radius)

    @staticmethod
    def resolve_collision(b1, b2):
        """Choc élastique 2D correct avec masses égales."""
        dx = b2.pos.x - b1.pos.x
        dy = b2.pos.y - b1.pos.y
        dist = math.sqrt(dx*dx + dy*dy)
        if dist == 0:
            dist = 0.01

        # Axe de collision normalisé
        nx = dx / dist
        ny = dy / dist

        # Séparation pour éviter l'interpénétration
        overlap = (b1.radius + b2.radius) - dist
        b1.pos.x -= nx * overlap / 2
        b1.pos.y -= ny * overlap / 2
        b2.pos.x += nx * overlap / 2
        b2.pos.y += ny * overlap / 2

        # Composantes des vitesses sur l'axe normal
        v1n = b1.vel.x * nx + b1.vel.y * ny
        v2n = b2.vel.x * nx + b2.vel.y * ny

        # Échange des composantes normales (masses égales)
        b1.vel.x += (v2n - v1n) * nx
        b1.vel.y += (v2n - v1n) * ny
        b2.vel.x += (v1n - v2n) * nx
        b2.vel.y += (v1n - v2n) * ny
