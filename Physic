# -*- coding: utf-8 -*-
"""Moteur physique pour BounceBox."""

import pygame

class PhysicsEngine:
    @staticmethod
    def handle_wall_collision(ball, width, height):
        r = ball.radius
        bounced = False
        if ball.pos.x - r <= 0:
            ball.pos.x = r
            ball.vel.x = abs(ball.vel.x)
            bounced = True
        elif ball.pos.x + r >= width:
            ball.pos.x = width - r
            ball.vel.x = -abs(ball.vel.x)
            bounced = True
        if ball.pos.y - r <= 0:
            ball.pos.y = r
            ball.vel.y = abs(ball.vel.y)
            bounced = True
        elif ball.pos.y + r >= height:
            ball.pos.y = height - r
            ball.vel.y = -abs(ball.vel.y)
            bounced = True
        return bounced

    @staticmethod
    def check_collision(b1, b2):
        # Utilisation de la méthode Pygame intégrée (très rapide)
        return b1.pos.distance_to(b2.pos) < (b1.radius + b2.radius)

    @staticmethod
    def resolve_collision(b1, b2):
        """Physique d'un choc élastique."""
        # Calcul de la distance entre les centres des deux balles
        delta = b2.pos - b1.pos
        dist = delta.magnitude()
        
        if dist == 0:
            dist = 0.01

        # Vecteur normal unitaire (n)
        n = delta / dist

        # Séparation pour éviter l'interpénétration (overlap)
        superposition = (b1.radius + b2.radius) - dist
        
        # Déplacement des balles suivant le vecteur normal
        b1.pos -= n * (superposition / 2)
        b2.pos += n * (superposition / 2)

        # Composantes des vitesses sur l'axe normal via le produit scalaire (dot)
        v1n = b1.vel.dot(n)
        v2n = b2.vel.dot(n)

        # Échange des composantes normales (puisqu'on est )
        b1.vel += (v2n - v1n) * n
        b2.vel += (v1n - v2n) * n
